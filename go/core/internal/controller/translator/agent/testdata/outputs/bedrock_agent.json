                  },
                  "initialDelaySeconds": 15,
                  "periodSeconds": 15,
                  "timeoutSeconds": 15
                },
                "resources": {
                  "limits": {
                    "cpu": "2",
                    "memory": "1Gi"
                  },
                  "requests": {
                    "cpu": "100m",
                    "memory": "384Mi"
                  }
                },
                "volumeMounts": [
                  {
                    "mountPath": "/config",
                    "name": "config"
                  },
                  {
                    "mountPath": "/var/run/secrets/tokens",
                    "name": "kagent-token"
                  }
                ]
              }
            ],
            "serviceAccountName": "bedrock-agent",
            "volumes": [
              {
                "name": "config",
                "secret": {
                  "secretName": "bedrock-agent"
                }
              },
              {
                "name": "kagent-token",
                "projected": {
                  "sources": [
