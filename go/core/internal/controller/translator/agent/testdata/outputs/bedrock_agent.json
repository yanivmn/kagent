              "app.kubernetes.io/part-of": "kagent",
              "kagent": "bedrock-agent"
            }
          },
          "spec": {
            "containers": [
              {
                "args": [
                  "--host",
                  "0.0.0.0",
                  "--port",
                  "8080",
                  "--filepath",
                  "/config"
                ],
                "env": [
                  {
                    "name": "AWS_REGION",
                    "value": "us-east-1"
                  },
                  {
                    "name": "AWS_ACCESS_KEY_ID",
